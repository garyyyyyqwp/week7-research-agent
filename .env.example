# GET https://s.jina.ai/{query} for search

# --- Agent ---
AGENT_MAX_STEPS=10

# --- Pipeline Parameters（新增 Week 7，有默认值）---
# RETRIEVE_TOP_K=8
# CHUNK_TARGET_TOKENS=300
# CHUNK_OVERLAP=0.15
# MIN_SOURCES=3
# PER_SEARCH_TIMEOUT=15
# EMBEDDING_BATCH_SIZE=10   # 阿里云 text-embedding-v3 批量上限为 10，勿调大
# EMBEDDING_MAX_RETRIES=3

# --- 安全（可选，有默认值）---
